# Database for scraped suppliers.
# Falls back to a local SQLite file if unset (great for trying it out).
# For production, reuse your Neon Postgres (a SEPARATE db/schema is recommended
# so it does not clobber the website's seeded `Supplier` table):
#   SCRAPER_DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
SCRAPER_DATABASE_URL=""

# Identify your crawler politely (required by many sites' ToS).
SCRAPER_USER_AGENT="SuplymateResearchBot/1.0 (+https://suplymate.com/bot)"

# Global politeness controls
SCRAPER_MIN_DELAY_SECONDS="3"     # minimum delay between requests to a host
SCRAPER_MAX_PAGES="2"             # max result pages per category per source
SCRAPER_TIMEOUT_SECONDS="30"
SCRAPER_RESPECT_ROBOTS="true"     # NEVER set false in production
