# Database — PostgreSQL (Neon / Vercel Postgres / Supabase)
# For Vercel/serverless use the POOLED connection string (host contains "-pooler").
# Example (Neon pooled):
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
# Lets Auth.js trust the deployment host (set automatically; keep for local)
AUTH_TRUST_HOST="true"

# Public site URL (production: https://suplymate.com)
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (ChatGPT) — enables the live AI procurement assistant instead of the
# built-in demo responses. Server-side only — NEVER prefix with NEXT_PUBLIC_.
# Get a key at https://platform.openai.com/api-keys
# Local: copy to .env.local → OPENAI_API_KEY=sk-...
# Production: Vercel → Project Settings → Environment Variables
OPENAI_API_KEY=""
# Optional: override the chat model (defaults to gpt-4o-mini when unset).
OPENAI_MODEL="gpt-4o-mini"

# Optional: Outscraper API key for the verified supplier directory pipeline.
# Get one at https://outscraper.com. Without it, the generated 100+ sample
# dataset is used. Pulls ONLY public Google Maps / business-listing data.
OUTSCRAPER_API_KEY=""

# Optional: Google Places API key. Extension point for enriching scraped
# suppliers with location/factory photos + verified contact data (see
# src/lib/scraper -> enrichWithPlacePhotos). Left unset = feature is a no-op.
GOOGLE_PLACES_API_KEY=""

# Optional scraper tuning (supplier website scraper, src/lib/scraper):
#   SCRAPE_DELAY_MS   politeness delay between requests (default 2500)
#   SCRAPE_TIMEOUT_MS per-request timeout (default 15000)
# SCRAPE_DELAY_MS="2500"
# SCRAPE_TIMEOUT_MS="15000"

# Admin access for the review queues (/admin/products, /admin/import-suppliers).
# Comma-separated email allowlist. If left empty, ANY signed-in user is treated
# as an admin (convenient for local/MVP; set this in production to lock it down).
ADMIN_EMAILS=""

# --- Local development checklist ---
# 1. Copy this file: cp .env.example .env.local (or add the DATABASE_* lines below to .env.local).
# 2. In Neon (or Vercel Postgres): copy POOLED → DATABASE_URL, DIRECT (non-pooler) → DIRECT_URL.
#    Pooled host contains "-pooler"; direct is the same URL with "-pooler" removed from the hostname.
# 3. Prisma CLI (`npm run db:push`) reads `.env` in the project root — not `.env.local`.
#    Either put DATABASE_URL + DIRECT_URL in `.env`, or keep Postgres URLs in both `.env` and `.env.local`.
#    Remove/replace any old `file:./dev.db` sqlite DATABASE_URL in `.env` or db:push will fail.
# 4. Run: npm run db:push && npm run import:bundle -- --file=scripts/import/examples/metalworks-china.json
#    If import ran while DB was down, cache is at scripts/import/cache/ — re-run import after db:push.
