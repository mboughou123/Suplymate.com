# Database — PostgreSQL (Neon / Vercel Postgres / Supabase)
# For Vercel/serverless use the POOLED connection string (host contains "-pooler").
# Example (Neon pooled):
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
# Lets Auth.js trust the deployment host (set automatically; keep for local)
AUTH_TRUST_HOST="true"

# Public site URL (production: https://suplymate.com)
NEXTAUTH_URL="http://localhost:3000"

# Optional: real AI responses (without this, the built-in demo AI is used)
OPENAI_API_KEY=""

# Optional: Outscraper API key for the verified supplier directory pipeline.
# Get one at https://outscraper.com. Without it, the generated 100+ sample
# dataset is used. Pulls ONLY public Google Maps / business-listing data.
OUTSCRAPER_API_KEY=""
