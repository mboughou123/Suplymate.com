generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  passwordHash  String
  company       String?
  createdAt     DateTime           @default(now())
  priceAlerts   PriceAlert[]
  conversations Conversation[]
  rfqs          Rfq[]
  notifications Notification[]
  favorites     FavoriteSupplier[]
}

model Supplier {
  id               String   @id
  name             String
  industry         String
  category         String?
  location         String
  country          String?
  city             String?
  website          String?
  phone            String?
  email            String?
  logoUrl          String?
  imageUrl         String?
  googleRating     Float?
  googleReviews    Int?
  description      String?
  products         String
  deliveryRegions  String
  moq              String
  verified         Boolean  @default(false)
  address          String?
  openingHours     String?
  sourceUrl        String?
  score            Int?
  reliabilityScore Int
  lastUpdated      DateTime @default(now()) @updatedAt

  // ----- Supplier import & scraping system (additive) -----
  // Moderation state for imported/scraped suppliers:
  // "pending" | "verified" | "rejected" | "needs_info". Scraped/imported
  // suppliers default to "pending" and require manual admin approval.
  verificationStatus  String   @default("pending")
  // JSON string[] of supplier/company gallery image URLs (separate from logoUrl).
  images              String   @default("[]")
  // JSON string[] of certification badge / certificate image URLs.
  certificationImages String   @default("[]")
  // JSON of denormalised certification details (name/type/etc.).
  certifications      String   @default("[]")
  // 0–100 trust score computed from completeness + signals (see lib/trust-score).
  trustScore          Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt

  // Relational certifications (the richer, queryable representation).
  certs               Certification[]

  @@index([category])
  @@index([country])
  @@index([score])
  @@index([verificationStatus])
}

// A certification / audit / compliance badge attached to a supplier. Captured
// either from a CSV import, the website scraper (certificationExtractor), or
// added/edited manually by an admin. Every record stores its public sourceUrl
// for attribution and review.
model Certification {
  id             String   @id @default(cuid())
  supplierId     String
  supplier       Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name           String
  // e.g. "ISO", "CE", "audit", "license", "award" — free-form classifier.
  type           String?
  imageUrl       String?
  certificateUrl String?
  sourceUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([supplierId])
}

model Product {
  id               String   @id
  name             String
  category         String
  priceMin         Float
  priceMax         Float
  currency         String
  bestDeliveryDays Int
  supplierCount    Int
  unit             String
}

model ScrapedProduct {
  id                   String   @id
  supplierId           String
  supplierName         String
  supplierLogo         String?
  name                 String
  category             String
  images               String   @default("[]")
  videos               String   @default("[]")
  basePrice            Float?
  commissionRate       Float?
  currency             String   @default("USD")
  moq                  String?
  shippingTime         String?
  description          String?
  specifications       String   @default("{}")
  customizationOptions String   @default("[]")
  certifications       String   @default("[]")
  rating               Float?
  reviewCount          Int?
  sourceUrl            String
  verifiedSupplier     Boolean  @default(false)
  status               String   @default("pending")
  scrapedAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt

  @@index([status])
  @@index([category])
}

model Material {
  id             String  @id
  name           String
  symbol         String
  currentPrice   Float
  unit           String
  currency       String
  dailyChange    Float
  monthlyChange  Float
  yearlyChange   Float
  signal         String
  history        String
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialId  String
  targetPrice Float
  notifyType  String
  createdAt   DateTime @default(now())
}

// ----- Supplier communication system -----

model Conversation {
  id            String    @id @default(cuid())
  buyerId       String
  buyer         User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  supplierId    String
  supplierName  String
  // inquiry | negotiation | sample_sent | order_in_progress | completed
  status        String    @default("inquiry")
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  messages      Message[]
  rfqs          Rfq[]

  @@index([buyerId])
  @@index([supplierId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // buyer | supplier | system
  senderType     String
  body           String
  translatedBody String?
  language       String?
  riskFlag       String? // e.g. "off_platform_payment"
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  attachments    Attachment[]

  @@index([conversationId])
}

model Attachment {
  id        String  @id @default(cuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String
  // image | pdf | spec | doc | other
  fileType  String
  url       String
  sizeBytes Int     @default(0)
}

model Rfq {
  id             String        @id @default(cuid())
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  buyerId        String
  buyer          User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  productName    String
  quantity       String
  destination    String?
  targetPrice    String?
  deadline       String?
  details        String?
  status         String        @default("open")
  createdAt      DateTime      @default(now())

  @@index([buyerId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // message | rfq | system
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model FavoriteSupplier {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplierId   String
  supplierName String
  createdAt    DateTime @default(now())

  @@unique([userId, supplierId])
  @@index([userId])
}
